{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ConnectionStrings": {
    "ProductionDatabase": "Server=JUDE7;Database=master;User Id=sa;Password=b35mart1c5?;TrustServerCertificate=True;"
  },

  // SQLite database shared between Agent and UI
  "DeadpoolDb": {
    "Path": "D:\\Deadpool\\deadpool.db"
  },

  // Backup policies – one entry per monitored database.
  // Cron expressions use 5-part standard format: minute hour day month weekday
  "BackupPolicies": [
    {
      "DatabaseName": "dev",
      "RecoveryModel": "Full",
      "FullBackupCron": "0 0 * * 0",
      "DifferentialBackupCron": "0 0 * * 1-6",
      "TransactionLogBackupCron": "*/15 * * * *",
      "RetentionDays": 14
    }
  ],

  // Execution worker settings
  "ExecutionWorker": {
    // Jobs in Running state older than this threshold are considered stale/abandoned.
    // Enables recovery after executor crash. Default: 2 hours.
    "StaleJobThreshold": "02:00:00"
  },

  // Backup file copy settings
  "BackupCopy": {
    // Network share path where backup files will be copied.
    // Leave empty to disable backup copying.
    // Example: "\\\\BackupServer\\Backups" or "Z:\\Backups"
    "RemoteStoragePath": "D:\\_temp_bakcup_db",

    // Maximum retry attempts for transient copy failures
    "MaxRetryAttempts": 3,

    // Delay between retry attempts
    "RetryDelay": "00:00:05"
  },

  // Health monitoring settings
  "HealthMonitoring": {
    // Interval between health checks for all databases
    "CheckInterval": "00:05:00",

    // Overdue thresholds for backup types
    "FullBackupOverdueThreshold": "26:00:00",
    "DifferentialBackupOverdueThreshold": "06:00:00",
    "LogBackupOverdueThreshold": "00:30:00",

    // How far back to look when validating backup chain integrity
    "ChainLookbackPeriod": "7.00:00:00",

    // Health check retention period in days
    "HealthCheckRetentionDays": 7
  },

  // Storage monitoring settings
  "StorageMonitoring": {
    // Interval between storage checks
    "CheckInterval": "00:10:00",

    // Warning threshold: alert when free space falls below this percentage
    "WarningThresholdPercentage": 20,

    // Critical threshold: alert when free space falls below this percentage
    "CriticalThresholdPercentage": 10,

    // Absolute minimum free space thresholds (in GB)
    // Alerts trigger if EITHER percentage OR absolute threshold is violated
    "MinimumWarningFreeSpaceGB": 50,
    "MinimumCriticalFreeSpaceGB": 20,

    // Storage health check retention period in days
    "HealthCheckRetentionDays": 7,

    // Volumes to monitor (leave empty to skip storage monitoring)
    // Examples: "C:\\Backups", "\\\\BackupServer\\Backups", "/mnt/backups"
    "MonitoredVolumes": []
  }
}
