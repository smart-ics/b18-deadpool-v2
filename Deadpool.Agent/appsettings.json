{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  // Backup policies – one entry per monitored database.
  // Cron expressions use 5-part standard format: minute hour day month weekday
  "BackupPolicies": [
    {
      "DatabaseName": "MyHospitalDB",
      "RecoveryModel": "Full",
      "FullBackupCron": "0 0 * * 0",
      "DifferentialBackupCron": "0 0 * * 1-6",
      "TransactionLogBackupCron": "*/15 * * * *",
      "RetentionDays": 14
    }
  ],

  // Execution worker settings
  "ExecutionWorker": {
    // Jobs in Running state older than this threshold are considered stale/abandoned.
    // Enables recovery after executor crash. Default: 2 hours.
    "StaleJobThreshold": "02:00:00"
  },

  // Backup file copy settings
  "BackupCopy": {
    // Network share path where backup files will be copied.
    // Leave empty to disable backup copying.
    // Example: "\\\\BackupServer\\Backups" or "Z:\\Backups"
    "RemoteStoragePath": "",

    // Maximum retry attempts for transient copy failures
    "MaxRetryAttempts": 3,

    // Delay between retry attempts
    "RetryDelay": "00:00:05"
  }
}
