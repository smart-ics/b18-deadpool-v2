<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="HeaderColor">#252526</Color>
    <Color x:Key="CardColor">#2A2A2A</Color>
    <Color x:Key="GreenColor">#4CAF50</Color>
    <Color x:Key="YellowColor">#FFC107</Color>
    <Color x:Key="RedColor">#F44336</Color>
    <Color x:Key="TextColor">#FFFFFF</Color>
    <Color x:Key="MutedTextColor">#B0B0B0</Color>
    <Color x:Key="GridBorderColor">#3A3A3A</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}" />
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="GridBorderBrush" Color="{StaticResource GridBorderColor}" />
</ResourceDictionary>
