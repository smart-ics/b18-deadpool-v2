<UserControl x:Class="Deadpool.UI.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Deadpool.UI.Wpf.Controls"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="720"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="110" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource HeaderBorderStyle}"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{Binding HeaderStatusBrush}"
                           Text="{Binding HeaderPrimaryText}" />

                <TextBlock Grid.Row="1"
                           Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding HeaderSecondaryText}" />

                <TextBlock Grid.Row="2"
                           Margin="0,4,0,0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Text="{Binding AgentStatusDisplay}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding BackupProgressVisibility}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,6"
                           Style="{StaticResource PanelHeadingTextStyle}"
                           Text="{Binding ProgressText, Mode=OneWay}" />

                <ProgressBar Grid.Row="1"
                             Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressPercent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding ProgressPercent, Mode=OneWay, StringFormat=Progress: {0:F2}%}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:StatusCard Grid.Column="0"
                                 Title="Last Backup"
                                 StatusText="{Binding LastBackupStatusText}"
                                 DetailText="{Binding LastBackupDetailText}"
                                 StatusColor="{Binding LastBackupStatusBrush}" />

            <controls:StatusCard Grid.Column="2"
                                 Title="Chain Health"
                                 StatusText="{Binding ChainHealthStatusText}"
                                 DetailText="{Binding ChainHealthDetailText}"
                                 StatusColor="{Binding ChainHealthStatusBrush}" />

            <controls:StatusCard Grid.Column="4"
                                 Title="Storage"
                                 StatusText="{Binding StorageStatusText}"
                                 DetailText="{Binding StorageDetailText}"
                                 StatusColor="{Binding StorageStatusBrush}" />

            <controls:StatusCard Grid.Column="6"
                                 Title="Database"
                                 StatusText="{Binding DatabaseStatusText}"
                                 DetailText="{Binding DatabaseDetailText}"
                                 StatusColor="{Binding DatabaseStatusBrush}" />
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               Style="{StaticResource PanelHeadingTextStyle}"
                               Text="Recent Jobs" />

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource DashboardDataGridStyle}"
                              ItemsSource="{Binding RecentJobs}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="*" />
                            <DataGridTemplateColumn Header="Status" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Status}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="SUCCESS">
                                                            <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="FAILED">
                                                            <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="PENDING">
                                                            <Setter Property="Foreground" Value="{StaticResource YellowBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               Style="{StaticResource PanelHeadingTextStyle}"
                               Text="Alerts" />

                    <StackPanel Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AlertItemBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource AlertMessageTextStyle}" Text="{Binding Message}" />
                                            <TextBlock Margin="0,3,0,0" Style="{StaticResource AlertActionTextStyle}" Text="{Binding Action}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
