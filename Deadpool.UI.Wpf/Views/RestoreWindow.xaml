<Window x:Class="Deadpool.UI.Wpf.Views.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Deadpool.UI.Wpf.Views"
        mc:Ignorable="d"
        Title="Restore Database"
        Width="980"
        Height="620"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <views:BoolToValidationTextConverter x:Key="BoolToValidationTextConverter" />
        <views:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Restore Database"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding DatabaseName, StringFormat=Target Database: {0}}"
                           FontSize="13"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource TextBrush}"
                           Text="Target Time" />

                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding TargetDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{StaticResource TextBrush}" Text="Hour" />
                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding Hours}"
                          SelectedItem="{Binding SelectedHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{StaticResource TextBrush}" Text="Minute" />
                <ComboBox Grid.Column="5"
                          ItemsSource="{Binding Minutes}"
                          SelectedItem="{Binding SelectedMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding TargetTime, StringFormat=Local: {0:yyyy-MM-dd HH:mm}}" />

                <Button Grid.Column="7"
                        Margin="12,0,0,0"
                        MinWidth="140"
                        Padding="12,6"
                        Command="{Binding GeneratePlanCommand}"
                        Content="Generate Plan" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,8"
                           Style="{StaticResource PanelHeadingTextStyle}"
                           Text="Restore Plan" />

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Plan.Steps}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Step" Width="110" DisplayMemberBinding="{Binding Type}" />
                            <GridViewColumn Header="Backup File" Width="350" DisplayMemberBinding="{Binding FileName}" />
                            <GridViewColumn Header="Timestamp" Width="200" DisplayMemberBinding="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                            <GridViewColumn Header="Marker" Width="170">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" Background="#3A7A3A">
                                            <TextBlock Text="STOPAT"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       Visibility="{Binding IsStopAt, Converter={StaticResource BoolToVisibility}}" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Style="{StaticResource PanelHeadingTextStyle}"
                           Text="Validation" />

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,8"
                           FontWeight="SemiBold"
                           Foreground="{Binding IsValid, Converter={StaticResource BoolToBrushConverter}}"
                           Text="{Binding IsValid, Converter={StaticResource BoolToValidationTextConverter}}" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#AA5500" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Errors" Foreground="#FF6B6B" FontWeight="Bold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FF9A9A" Margin="0,2,0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="#8A7500" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Warnings" Foreground="#FFE08A" FontWeight="Bold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding ValidationWarnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FFF2B2" Margin="0,2,0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox IsChecked="{Binding IsConfirmed, Mode=TwoWay}"
                          Foreground="{StaticResource TextBrush}"
                          Content="I understand this will overwrite database" />

                <TextBlock Margin="0,8,0,4"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Type database name to confirm:" />

                <TextBox Text="{Binding ConfirmationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="256" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    MinWidth="160"
                    Padding="12,6"
                    Command="{Binding ExecuteRestoreCommand}"
                    Content="Execute Restore" />

            <Button Grid.Column="3"
                    MinWidth="100"
                    Padding="12,6"
                    IsCancel="True"
                    Click="OnCancelClick"
                    Content="Cancel" />
        </Grid>

        <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
