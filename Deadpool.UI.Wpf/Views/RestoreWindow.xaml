<Window x:Class="Deadpool.UI.Wpf.Views.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Deadpool.UI.Wpf.Views"
        mc:Ignorable="d"
        Title="Restore Database"
        Width="1180"
        Height="700"
        MinWidth="1100"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <views:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <views:BoolToValidationTextConverter x:Key="BoolToValidationTextConverter" />
        <views:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Restore Database"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding DatabaseName, StringFormat=Target Database: {0}}"
                           FontSize="13"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Foreground="{StaticResource TextBrush}"
                           Text="Choose one valid restore point from backup history." />

                <Button Grid.Column="1"
                        MinWidth="160"
                        Padding="12,6"
                        Command="{Binding RefreshRestorePointsCommand}"
                        Content="Refresh Points" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource PanelHeadingTextStyle}"
                               Text="Available Restore Points" />

                    <ListBox Grid.Row="1"
                             Margin="0,8,0,0"
                             ItemsSource="{Binding RestorePoints}"
                             SelectedItem="{Binding SelectedRestorePoint, Mode=TwoWay}"
                             BorderThickness="1"
                             BorderBrush="#2B3B4A"
                             Background="#13212C"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TimeText}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TypeText}"
                                               Foreground="#7CC2FF"
                                               FontWeight="Bold" />

                                    <TextBlock Grid.Column="2"
                                               Text="Unavailable"
                                               Foreground="#D09A6E"
                                               Visibility="{Binding IsSelectable, Converter={StaticResource InverseBoolToVisibility}}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource PanelHeadingTextStyle}"
                               Text="Restore Plan" />

                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,8"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{Binding RestorePlanSummary}" />

                    <Grid Grid.Row="2" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Base"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding BaseBackupSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Logs"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LogChainSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="StopAt"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StopAtSummary}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Expander Grid.Row="5"
                              IsExpanded="{Binding ShowPlanDetails, Mode=TwoWay}"
                              Header="Details"
                              Foreground="{StaticResource TextBrush}">
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Plan.Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding StepType}"
                                                   Foreground="#7CC2FF"
                                                   FontWeight="Bold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="STOPAT"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#FFE08A"
                                                   Visibility="{Binding IsStopAt, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Status"
                           VerticalAlignment="Top"
                           Foreground="{StaticResource MutedTextBrush}" />

                <StackPanel Grid.Column="1">
                    <TextBlock FontWeight="Bold"
                               Foreground="{Binding IsValid, Converter={StaticResource BoolToBrushConverter}}"
                               Text="{Binding IsValid, Converter={StaticResource BoolToValidationTextConverter}}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="44" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <CheckBox IsChecked="{Binding IsConfirmed, Mode=TwoWay}"
                              Foreground="{StaticResource TextBrush}"
                              Content="I understand this operation overwrites the selected database." />

                    <TextBlock Margin="0,8,0,4"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Type database name to confirm (required when strict text-match is enabled):" />
                    <TextBox Text="{Binding ConfirmationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsConfirmed}"
                             MaxLength="256" />
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            MinWidth="180"
                            Padding="12,6"
                            Command="{Binding ExecuteRestoreCommand}"
                            Content="Execute Restore" />

                    <Button Grid.Column="3"
                            MinWidth="100"
                            Padding="12,6"
                            IsCancel="True"
                            Click="OnCancelClick"
                            Content="Cancel" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
